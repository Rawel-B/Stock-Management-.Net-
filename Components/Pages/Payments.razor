@page "/payments"
@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject OrderWorkflowService Workflow
@inject ISnackbar Snackbar

<PageTitle>Payments</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Online payments</MudText>

    <MudTable Items="_payments" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Order</MudTh>
            <MudTh>Client</MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Mode</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Date</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Order">#@context.OrderId</MudTd>
            <MudTd DataLabel="Client">@context.Order?.Client?.Name</MudTd>
            <MudTd DataLabel="Amount">@context.Order?.TotalAmount.ToString("C")</MudTd>
            <MudTd DataLabel="Mode">@context.Mode</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="@PaymentColor(context.Status)">@context.Status</MudChip></MudTd>
            <MudTd DataLabel="Date">@context.Date.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => MarkPayment(context.OrderId, PaymentStatus.Paid))">Mark paid</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => MarkPayment(context.OrderId, PaymentStatus.Failed))">Fail</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private List<Payment> _payments = [];

    protected override async Task OnInitializedAsync() => await LoadPayments();

    private async Task LoadPayments()
    {
        _payments = await DbContext.Payments
            .Include(payment => payment.Order)
            .ThenInclude(order => order!.Client)
            .OrderByDescending(payment => payment.Date)
            .ToListAsync();
    }

    private async Task MarkPayment(int orderId, PaymentStatus status)
    {
        await Workflow.MarkPaymentAsync(orderId, status, PaymentMode.OnlineGateway);
        await LoadPayments();
        Snackbar.Add("Payment updated.", Severity.Success);
    }

    private static Color PaymentColor(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => Color.Success,
        PaymentStatus.Failed => Color.Error,
        PaymentStatus.Refunded => Color.Info,
        _ => Color.Warning
    };
}
