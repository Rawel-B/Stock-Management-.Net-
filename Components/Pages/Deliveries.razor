@page "/deliveries"
@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject OrderWorkflowService Workflow
@inject ISnackbar Snackbar

<PageTitle>Deliveries</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Deliveries</MudText>

    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_delivery.OrderId" Label="Validated order">
                    @foreach (var order in _validatedOrders)
                    {
                        <MudSelectItem Value="@order.Id">#@order.Id - @order.Client?.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_delivery.TransporterId" Label="Transporter">
                    @foreach (var transporter in _transporters)
                    {
                        <MudSelectItem Value="@transporter.Id">@transporter.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2"><MudDatePicker @bind-Date="_deliveryDate" Label="Delivery date" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField @bind-Value="_delivery.Cost" Label="Cost" Min="0" /></MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LocalShipping" OnClick="CreateDelivery">Schedule</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="_deliveries" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Order</MudTh>
            <MudTh>Client</MudTh>
            <MudTh>Transporter</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>Cost</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Order">#@context.OrderId</MudTd>
            <MudTd DataLabel="Client">@context.Order?.Client?.Name</MudTd>
            <MudTd DataLabel="Transporter">@context.Transporter?.Name</MudTd>
            <MudTd DataLabel="Date">@context.DeliveryDate.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd DataLabel="Cost">@context.Cost.ToString("C")</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="@DeliveryColor(context.Status)">@context.Status</MudChip></MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => MarkDelivery(context.Id, DeliveryStatus.InTransit))">Ship</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => MarkDelivery(context.Id, DeliveryStatus.Delivered))">Deliver</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private Delivery _delivery = new();
    private DateTime? _deliveryDate = DateTime.Today.AddDays(2);
    private List<Order> _validatedOrders = [];
    private List<Transporter> _transporters = [];
    private List<Delivery> _deliveries = [];

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _validatedOrders = await DbContext.Orders
            .Include(order => order.Client)
            .Where(order => order.Status == OrderStatus.Validated && order.Delivery == null)
            .OrderByDescending(order => order.Date)
            .ToListAsync();
        _transporters = await DbContext.Transporters.OrderBy(transporter => transporter.Name).ToListAsync();
        _deliveries = await DbContext.Deliveries
            .Include(delivery => delivery.Order)
            .ThenInclude(order => order!.Client)
            .Include(delivery => delivery.Transporter)
            .OrderByDescending(delivery => delivery.DeliveryDate)
            .ToListAsync();
        _delivery.OrderId = _validatedOrders.FirstOrDefault()?.Id ?? 0;
        _delivery.TransporterId = _transporters.FirstOrDefault()?.Id ?? 0;
    }

    private async Task CreateDelivery()
    {
        if (_delivery.OrderId == 0 || _delivery.TransporterId == 0)
        {
            Snackbar.Add("Select an order and a transporter.", Severity.Warning);
            return;
        }

        _delivery.DeliveryDate = (_deliveryDate ?? DateTime.Today).ToUniversalTime();
        DbContext.Deliveries.Add(_delivery);
        await DbContext.SaveChangesAsync();
        _delivery = new Delivery();
        await LoadData();
        Snackbar.Add("Delivery scheduled.", Severity.Success);
    }

    private async Task MarkDelivery(int deliveryId, DeliveryStatus status)
    {
        await Workflow.MarkDeliveryAsync(deliveryId, status);
        await LoadData();
        Snackbar.Add("Delivery updated.", Severity.Success);
    }

    private static Color DeliveryColor(DeliveryStatus status) => status switch
    {
        DeliveryStatus.InTransit => Color.Warning,
        DeliveryStatus.Delivered => Color.Success,
        DeliveryStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
