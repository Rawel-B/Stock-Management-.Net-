@page "/clients"
@attribute [Authorize]
@inject ClientService ClientService
@inject ISnackbar Snackbar

<PageTitle>Clients</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading">
        <div class="page-heading-text">
            <MudText Typo="Typo.h4">Clients</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Maintain customer contact and delivery details.</MudText>
        </div>
    </div>

    <MudPaper Class="section-panel pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@(_client.Id == 0 ? "Add client" : "Edit client")</MudText>
        <MudGrid>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_client.Name" Label="Name" Required="true" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_client.Email" Label="Email" Required="true" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_client.Address" Label="Address" Required="true" /></MudItem>
            <MudItem xs="12" md="2" Class="form-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveClient">Save</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="table-shell" Elevation="0">
        <MudTable Items="_clients" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Address</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Address">@context.Address</MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditClient(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteClient(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">No clients have been added yet.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private ClientEditModel _client = new();
    private List<ClientViewModel> _clients = [];

    protected override async Task OnInitializedAsync() => await LoadClients();

    private async Task LoadClients()
    {
        _clients = await ClientService.GetClientsAsync();
    }

    private async Task SaveClient()
    {
        if (string.IsNullOrWhiteSpace(_client.Name) || string.IsNullOrWhiteSpace(_client.Email))
        {
            Snackbar.Add("Name and email are required.", Severity.Warning);
            return;
        }

        await ClientService.SaveClientAsync(_client);
        _client = new ClientEditModel();
        await LoadClients();
        Snackbar.Add("Client saved.", Severity.Success);
    }

    private void EditClient(ClientViewModel client)
    {
        _client = new ClientEditModel
        {
            Id = client.Id,
            Name = client.Name,
            Email = client.Email,
            Address = client.Address
        };
    }

    private async Task DeleteClient(ClientViewModel client)
    {
        await ClientService.DeleteClientAsync(client.Id);
        await LoadClients();
        Snackbar.Add("Client deleted.", Severity.Info);
    }
}
