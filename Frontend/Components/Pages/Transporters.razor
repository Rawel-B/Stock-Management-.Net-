@page "/transporters"
@attribute [Authorize]
@inject TransporterService TransporterService
@inject ISnackbar Snackbar

<PageTitle>Transporters</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading">
        <div class="page-heading-text">
            <MudText Typo="Typo.h4">Transporters</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage carriers used for scheduled deliveries.</MudText>
        </div>
    </div>

    <MudPaper Class="section-panel pa-4" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@(_transporter.Id == 0 ? "Add transporter" : "Edit transporter")</MudText>
        <MudGrid>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_transporter.Name" Label="Name" Required="true" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_transporter.Phone" Label="Phone" Required="true" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField @bind-Value="_transporter.Rating" Label="Rating" Min="1" Max="5" /></MudItem>
            <MudItem xs="12" md="2" Class="form-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveTransporter">Save</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="table-shell" Elevation="0">
        <MudTable Items="_transporters" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Phone</MudTh>
                <MudTh>Rating</MudTh>
                <MudTh>Deliveries</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Phone">@context.Phone</MudTd>
                <MudTd DataLabel="Rating">
                    <MudRating SelectedValue="@context.Rating" ReadOnly="true" />
                </MudTd>
                <MudTd DataLabel="Deliveries">@context.DeliveryCount</MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditTransporter(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteTransporter(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">No transporters available.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private TransporterEditModel _transporter = new();
    private List<TransporterViewModel> _transporters = [];

    protected override async Task OnInitializedAsync() => await LoadTransporters();

    private async Task LoadTransporters()
    {
        _transporters = await TransporterService.GetTransportersAsync();
    }

    private async Task SaveTransporter()
    {
        if (string.IsNullOrWhiteSpace(_transporter.Name) || string.IsNullOrWhiteSpace(_transporter.Phone))
        {
            Snackbar.Add("Name and phone are required.", Severity.Warning);
            return;
        }

        await TransporterService.SaveTransporterAsync(_transporter);
        _transporter = new TransporterEditModel();
        await LoadTransporters();
        Snackbar.Add("Transporter saved.", Severity.Success);
    }

    private void EditTransporter(TransporterViewModel transporter)
    {
        _transporter = new TransporterEditModel
        {
            Id = transporter.Id,
            Name = transporter.Name,
            Phone = transporter.Phone,
            Rating = transporter.Rating
        };
    }

    private async Task DeleteTransporter(TransporterViewModel transporter)
    {
        await TransporterService.DeleteTransporterAsync(transporter.Id);
        await LoadTransporters();
        Snackbar.Add("Transporter deleted.", Severity.Info);
    }
}
