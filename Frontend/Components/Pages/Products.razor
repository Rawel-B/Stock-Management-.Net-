@page "/products"
@attribute [Authorize]
@inject ProductService ProductService
@inject ISnackbar Snackbar

<PageTitle>Products</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Products and suppliers</MudText>

    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="_product.Sku" Label="SKU" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_product.Name" Label="Product" Required="true" /></MudItem>
            <MudItem xs="6" md="2"><MudNumericField @bind-Value="_product.StockQuantity" Label="Stock" Min="0" /></MudItem>
            <MudItem xs="6" md="2"><MudNumericField @bind-Value="_product.UnitPrice" Label="Unit price" Min="0" /></MudItem>
            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="_product.SupplierId" Label="Supplier" Clearable="true">
                    @foreach (var supplier in _suppliers)
                    {
                        <MudSelectItem T="int?" Value="@supplier.Id">@supplier.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="1" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveProduct">Save</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="_products" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Product</MudTh>
            <MudTh>Supplier</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Price</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="SKU">@context.Sku</MudTd>
            <MudTd DataLabel="Product">@context.Name</MudTd>
            <MudTd DataLabel="Supplier">@context.SupplierName</MudTd>
            <MudTd DataLabel="Stock"><MudChip T="string" Size="Size.Small" Color="@(context.StockQuantity <= 10 ? Color.Warning : Color.Success)">@context.StockQuantity</MudChip></MudTd>
            <MudTd DataLabel="Price">@context.UnitPrice.ToString("C")</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditProduct(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteProduct(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private ProductEditModel _product = new();
    private List<ProductViewModel> _products = [];
    private List<SelectOptionViewModel> _suppliers = [];

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _suppliers = await ProductService.GetSupplierOptionsAsync();
        _products = await ProductService.GetProductsAsync();
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(_product.Name))
        {
            Snackbar.Add("Product name is required.", Severity.Warning);
            return;
        }

        await ProductService.SaveProductAsync(_product);
        _product = new ProductEditModel();
        await LoadData();
        Snackbar.Add("Product saved.", Severity.Success);
    }

    private void EditProduct(ProductViewModel product)
    {
        _product = new ProductEditModel
        {
            Id = product.Id,
            Name = product.Name,
            Sku = product.Sku,
            StockQuantity = product.StockQuantity,
            UnitPrice = product.UnitPrice,
            SupplierId = product.SupplierId
        };
    }

    private async Task DeleteProduct(ProductViewModel product)
    {
        await ProductService.DeleteProductAsync(product.Id);
        await LoadData();
        Snackbar.Add("Product deleted.", Severity.Info);
    }
}
