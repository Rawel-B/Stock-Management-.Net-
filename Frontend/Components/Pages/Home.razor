@page "/"
@attribute [Authorize]
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading">
        <div class="page-heading-text">
            <MudText Typo="Typo.h4">Operations dashboard</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Monitor orders, inventory pressure, payments, and recent activity.</MudText>
        </div>
        <MudButton Href="orders" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
            New order
        </MudButton>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="metric-card pa-4" Elevation="0">
                <div class="metric-card-content">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Open orders</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.OpenOrders</MudText>
                    </div>
                    <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" /></span>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="metric-card pa-4" Elevation="0">
                <div class="metric-card-content">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Low stock</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.LowStockProducts</MudText>
                    </div>
                    <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Inventory" /></span>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="metric-card pa-4" Elevation="0">
                <div class="metric-card-content">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pending payments</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.PendingPayments</MudText>
                    </div>
                    <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Payments" /></span>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Class="metric-card pa-4" Elevation="0">
                <div class="metric-card-content">
                    <div>
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Revenue tracked</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.Revenue.ToString("C")</MudText>
                    </div>
                    <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></span>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="section-panel pa-4" Elevation="0">
        <div class="toolbar-row">
            <div>
                <MudText Typo="Typo.h6">Recent orders</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Latest operational activity across clients.</MudText>
            </div>
            <MudButton Href="orders" Variant="Variant.Outlined" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">
                View orders
            </MudButton>
        </div>
        <MudTable Items="_dashboard.RecentOrders" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Order</MudTh>
                <MudTh>Client</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Total</MudTh>
                <MudTh>Date</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Order">#@context.Id</MudTd>
                <MudTd DataLabel="Client">@context.ClientName</MudTd>
                <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
                <MudTd DataLabel="Total">@context.TotalAmount.ToString("C")</MudTd>
                <MudTd DataLabel="Date">@context.Date.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">No orders yet.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private DashboardViewModel _dashboard = new();

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await DashboardService.GetDashboardAsync();
    }

    private static Color StatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Validated => Color.Info,
        OrderStatus.Shipped => Color.Warning,
        OrderStatus.Delivered => Color.Success,
        OrderStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
